# Shared secret used to validate preview requests.
# Must match the token appended to the preview URL (e.g. ?preview=<secret>).
NUXT_PREVIEW_SECRET=your-shared-preview-secret

# A Sanity API token with at least Viewer permissions.
# Used server-side to fetch draft documents when preview mode is active.
# Create one at: https://www.sanity.io/manage/project/j1o4tmjp/api#tokens
NUXT_SANITY_PREVIEW_TOKEN=your-sanity-api-token
